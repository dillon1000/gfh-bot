generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PollMode {
  single
  multi
  ranked
}

enum PollClosedReason {
  closed
  cancelled
}

enum RemovalVoteRequestStatus {
  collecting
  waiting
  initiated
  expired
}

enum RemovalVoteSupportKind {
  request
  second
}

enum AuditLogBucket {
  primary
  noisy
}

enum AuditLogSource {
  gateway
  audit
  bot
}

enum AuditLogDeliveryStatus {
  pending
  delivered
  failed
}

enum MarketTradeSide {
  buy
  sell
}

model GuildConfig {
  id                 String           @id @default(cuid())
  guildId            String           @unique
  starboardEnabled   Boolean          @default(false)
  starboardChannelId String?
  starboardThreshold Int              @default(3)
  starboardEmojis    String[]         @default([])
  starboardBlacklistedChannelIds String[] @default([])
  searchIgnoredChannelIds String[]    @default([])
  auditLogChannelId  String?
  auditLogNoisyChannelId String?
  marketEnabled      Boolean          @default(false)
  marketChannelId    String?
  starboardEmojiId   String?
  starboardEmojiName String?
  memberRoleId       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  starboardEntries   StarboardEntry[]
  marketAccounts     MarketAccount[]
}

model Poll {
  id             String          @id @default(cuid())
  guildId        String
  channelId      String
  messageId      String?         @unique
  threadId       String?         @unique
  authorId       String
  question       String
  description    String?
  mode           PollMode        @default(single)
  singleSelect   Boolean         @default(true)
  anonymous      Boolean         @default(false)
  quorumPercent  Int?
  allowedRoleIds String[]        @default([])
  blockedRoleIds String[]        @default([])
  eligibleChannelIds String[]    @default([])
  passThreshold  Int?
  passOptionIndex Int?
  reminderRoleId String?
  durationMinutes Int
  closesAt       DateTime
  closedAt       DateTime?
  closedReason   PollClosedReason?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  options        PollOption[]
  reminders      PollReminder[]
  votes          PollVote[]
  voteEvents     PollVoteEvent[]

  @@index([guildId, channelId])
  @@index([closesAt, closedAt])
}

model PollReminder {
  id            String   @id @default(cuid())
  pollId        String
  offsetMinutes Int
  remindAt      DateTime
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  poll          Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, offsetMinutes])
  @@index([pollId])
  @@index([remindAt, sentAt])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  label     String
  emoji     String?
  sortOrder Int
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  rank      Int?
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionId])
  @@unique([pollId, userId, rank])
  @@index([pollId, userId])
}

model PollVoteEvent {
  id                String   @id @default(cuid())
  pollId            String
  userId            String
  previousOptionIds String[]
  nextOptionIds     String[]
  createdAt         DateTime @default(now())
  poll              Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId, createdAt])
  @@index([pollId, userId, createdAt])
}

model StarboardEntry {
  id              String      @id @default(cuid())
  guildConfigId   String
  sourceMessageId String      @unique
  sourceChannelId String
  boardMessageId  String      @unique
  boardChannelId  String
  authorId        String
  sourceAuthorName String
  sourceContent   String?
  sourceImageUrl  String?
  reactionCount   Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  guildConfig     GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)

  @@index([guildConfigId])
}

model ReactionRolePanel {
  id          String               @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?              @unique
  title       String
  description String?
  exclusive   Boolean              @default(false)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  options     ReactionRoleOption[]

  @@index([guildId, channelId])
}

model ReactionRoleOption {
  id        String            @id @default(cuid())
  panelId   String
  roleId    String
  label     String
  sortOrder Int
  createdAt DateTime          @default(now())
  panel     ReactionRolePanel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([panelId, roleId])
  @@unique([panelId, sortOrder])
  @@index([panelId])
}

model RemovalVoteRequest {
  id                  String                   @id @default(cuid())
  guildId             String
  targetUserId        String
  pollChannelId       String
  originChannelId     String
  status              RemovalVoteRequestStatus @default(collecting)
  supportWindowEndsAt DateTime
  thresholdReachedAt  DateTime?
  waitUntil           DateTime?
  initiateBy          DateTime?
  initiatedPollId     String?
  lastAutoStartError  String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  supports            RemovalVoteSupport[]

  @@index([guildId, targetUserId, status])
  @@index([status, waitUntil])
  @@index([status, initiateBy])
}

model RemovalVoteSupport {
  id          String                 @id @default(cuid())
  requestId   String
  supporterId String
  kind        RemovalVoteSupportKind
  channelId   String
  createdAt   DateTime               @default(now())
  request     RemovalVoteRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, supporterId])
  @@index([requestId, createdAt])
}

model Market {
  id                     String           @id @default(cuid())
  guildId                String
  creatorId              String
  originChannelId        String
  marketChannelId        String
  messageId              String?          @unique
  title                  String
  description            String?
  tags                   String[]         @default([])
  liquidityParameter     Int              @default(150)
  closeAt                DateTime
  tradingClosedAt        DateTime?
  resolutionGraceEndsAt  DateTime?
  graceNotifiedAt        DateTime?
  resolvedAt             DateTime?
  cancelledAt            DateTime?
  resolutionNote         String?
  resolutionEvidenceUrl  String?
  resolvedByUserId       String?
  winningOutcomeId       String?
  totalVolume            Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  winningOutcome         MarketOutcome?   @relation("MarketWinningOutcome", fields: [winningOutcomeId], references: [id], onDelete: SetNull)
  outcomes               MarketOutcome[]
  trades                 MarketTrade[]
  positions              MarketPosition[]

  @@index([guildId, closeAt, tradingClosedAt])
  @@index([guildId, resolvedAt, cancelledAt])
  @@index([guildId, creatorId, createdAt])
}

model MarketOutcome {
  id                String           @id @default(cuid())
  marketId          String
  label             String
  sortOrder         Int
  outstandingShares Float            @default(0)
  createdAt         DateTime         @default(now())
  market            Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  trades            MarketTrade[]
  positions         MarketPosition[]
  wonMarkets        Market[]         @relation("MarketWinningOutcome")

  @@unique([marketId, sortOrder])
  @@index([marketId])
}

model MarketTrade {
  id                   String           @id @default(cuid())
  marketId             String
  outcomeId            String
  userId               String
  side                 MarketTradeSide
  cashDelta            Int
  shareDelta           Float
  probabilitySnapshot  Float
  cumulativeVolume     Int
  createdAt            DateTime         @default(now())
  market               Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome              MarketOutcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
  @@index([marketId, userId, createdAt])
}

model MarketPosition {
  id         String        @id @default(cuid())
  marketId   String
  outcomeId  String
  userId     String
  shares     Float         @default(0)
  costBasis  Float         @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  market     Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome    MarketOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeId, userId])
  @@index([marketId, userId])
}

model MarketAccount {
  id              String      @id @default(cuid())
  guildConfigId   String
  guildId         String
  userId          String
  bankroll        Float       @default(1000)
  realizedProfit  Float       @default(0)
  lastTopUpAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  guildConfig     GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildConfigId])
  @@index([guildId, bankroll, realizedProfit])
}

model GuildEventLogEntry {
  id                String                 @id @default(cuid())
  guildId           String
  bucket            AuditLogBucket
  source            AuditLogSource
  eventName         String
  payload           Json
  occurredAt        DateTime               @default(now())
  deliveryStatus    AuditLogDeliveryStatus @default(pending)
  deliveredAt       DateTime?
  deliveredMessageId String?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([guildId, occurredAt])
  @@index([deliveryStatus, occurredAt])
  @@index([deliveryStatus, occurredAt, id])
}

model GuildMessageSnapshot {
  messageId         String   @id
  guildId           String
  channelId         String
  authorId          String?
  firstSeenPayload  Json
  latestPayload     Json
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([guildId, channelId])
  @@index([guildId, updatedAt])
}
