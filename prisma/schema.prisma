generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PollMode {
  single
  multi
  ranked
}

enum PollClosedReason {
  closed
  cancelled
}

enum RemovalVoteRequestStatus {
  collecting
  waiting
  initiated
  expired
}

enum RemovalVoteSupportKind {
  request
  second
}

enum AuditLogBucket {
  primary
  noisy
}

enum AuditLogSource {
  gateway
  audit
  bot
}

enum AuditLogDeliveryStatus {
  pending
  delivered
  failed
}

enum MarketTradeSide {
  buy
  sell
  short
  cover
}

enum MarketPositionSide {
  long
  short
}

enum MarketButtonStyle {
  primary
  secondary
  success
  danger
}

enum MarketContractMode {
  categorical_single_winner
  independent_binary_set
  competitive_multi_winner
}

enum CasinoGameKind {
  slots
  blackjack
  poker
  rtd
  holdem
}

enum CasinoRoundResult {
  win
  loss
  push
}

enum CasinoTableStatus {
  lobby
  active
  closed
}

enum CasinoSeatStatus {
  seated
  left
  busted
}

enum CasinoTableActionKind {
  create
  join
  leave
  start
  close
  add_bot
  remove_bot
  pause
  resume
  bot_action
  hit
  stand
  double_down
  fold
  check
  call
  raise
  timeout
  auto_action
  cash_out
}

model GuildConfig {
  id                 String           @id @default(cuid())
  guildId            String           @unique
  starboardEnabled   Boolean          @default(false)
  starboardChannelId String?
  starboardThreshold Int              @default(3)
  starboardAllowAnyEmoji Boolean      @default(false)
  starboardEmojis    String[]         @default([])
  starboardBlacklistedChannelIds String[] @default([])
  searchIgnoredChannelIds String[]    @default([])
  auditLogChannelId  String?
  auditLogNoisyChannelId String?
  marketEnabled      Boolean          @default(false)
  marketChannelId    String?
  casinoEnabled      Boolean          @default(false)
  casinoChannelId    String?
  starboardEmojiId   String?
  starboardEmojiName String?
  memberRoleId       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  starboardEntries   StarboardEntry[]
  marketAccounts     MarketAccount[]
  casinoTables       CasinoTable[]
}

model Poll {
  id             String          @id @default(cuid())
  guildId        String
  channelId      String
  messageId      String?         @unique
  threadId       String?         @unique
  authorId       String
  question       String
  description    String?
  mode           PollMode        @default(single)
  singleSelect   Boolean         @default(true)
  anonymous      Boolean         @default(false)
  quorumPercent  Int?
  allowedRoleIds String[]        @default([])
  blockedRoleIds String[]        @default([])
  eligibleChannelIds String[]    @default([])
  passThreshold  Int?
  passOptionIndex Int?
  reminderRoleId String?
  durationMinutes Int
  closesAt       DateTime
  closedAt       DateTime?
  closedReason   PollClosedReason?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  options        PollOption[]
  reminders      PollReminder[]
  votes          PollVote[]
  voteEvents     PollVoteEvent[]
  @@index([guildId, channelId])
  @@index([closesAt, closedAt])
}

model PollReminder {
  id            String   @id @default(cuid())
  pollId        String
  offsetMinutes Int
  remindAt      DateTime
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  poll          Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, offsetMinutes])
  @@index([pollId])
  @@index([remindAt, sentAt])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  label     String
  emoji     String?
  sortOrder Int
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  rank      Int?
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionId])
  @@unique([pollId, userId, rank])
  @@index([pollId, userId])
}

model PollVoteEvent {
  id                String   @id @default(cuid())
  pollId            String
  userId            String
  previousOptionIds String[]
  nextOptionIds     String[]
  createdAt         DateTime @default(now())
  poll              Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId, createdAt])
  @@index([pollId, userId, createdAt])
}

model StarboardEntry {
  id              String      @id @default(cuid())
  guildConfigId   String
  sourceMessageId String      @unique
  sourceChannelId String
  boardMessageId  String      @unique
  boardChannelId  String
  authorId        String
  sourceAuthorName String
  sourceContent   String?
  sourceImageUrl  String?
  reactionCount   Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  guildConfig     GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)

  @@index([guildConfigId])
}

model ReactionRolePanel {
  id          String               @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?              @unique
  title       String
  description String?
  exclusive   Boolean              @default(false)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  options     ReactionRoleOption[]

  @@index([guildId, channelId])
}

model ReactionRoleOption {
  id        String            @id @default(cuid())
  panelId   String
  roleId    String
  label     String
  sortOrder Int
  createdAt DateTime          @default(now())
  panel     ReactionRolePanel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([panelId, roleId])
  @@unique([panelId, sortOrder])
  @@index([panelId])
}

model RemovalVoteRequest {
  id                  String                   @id @default(cuid())
  guildId             String
  targetUserId        String
  pollChannelId       String
  originChannelId     String
  status              RemovalVoteRequestStatus @default(collecting)
  supportWindowEndsAt DateTime
  thresholdReachedAt  DateTime?
  waitUntil           DateTime?
  initiateBy          DateTime?
  initiatedPollId     String?
  lastAutoStartError  String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  supports            RemovalVoteSupport[]

  @@index([guildId, targetUserId, status])
  @@index([status, waitUntil])
  @@index([status, initiateBy])
}

model RemovalVoteSupport {
  id          String                 @id @default(cuid())
  requestId   String
  supporterId String
  kind        RemovalVoteSupportKind
  channelId   String
  createdAt   DateTime               @default(now())
  request     RemovalVoteRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, supporterId])
  @@index([requestId, createdAt])
}

model Market {
  id                     String           @id @default(cuid())
  guildId                String
  creatorId              String
  originChannelId        String
  marketChannelId        String
  messageId              String?          @unique
  threadId               String?          @unique
  title                  String
  description            String?
  buttonStyle            MarketButtonStyle @default(primary)
  contractMode           MarketContractMode @default(categorical_single_winner)
  winnerCount            Int              @default(1)
  tags                   String[]         @default([])
  baseLiquidityParameter Int              @default(150)
  liquidityParameter     Int              @default(150)
  maxLiquidityParameter  Int              @default(450)
  lastLiquidityInjectionAt DateTime?
  closeAt                DateTime
  tradingClosedAt        DateTime?
  resolutionGraceEndsAt  DateTime?
  graceNotifiedAt        DateTime?
  resolvedAt             DateTime?
  cancelledAt            DateTime?
  resolutionNote         String?
  resolutionEvidenceUrl  String?
  resolvedByUserId       String?
  winningOutcomeId       String?
  totalVolume            Float            @default(0)
  supplementaryBonusPool Float            @default(0)
  supplementaryBonusDistributedAt DateTime?
  supplementaryBonusExpiredAt DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  winningOutcome         MarketOutcome?   @relation("MarketWinningOutcome", fields: [winningOutcomeId], references: [id], onDelete: SetNull)
  outcomes               MarketOutcome[]
  trades                 MarketTrade[]
  positions              MarketPosition[]
  lossProtections        MarketLossProtection[]
  forecastRecords        MarketForecastRecord[]
  liquidityEvents        MarketLiquidityEvent[]

  @@index([guildId, closeAt, tradingClosedAt])
  @@index([guildId, resolvedAt, cancelledAt])
  @@index([guildId, creatorId, createdAt])
}

model MarketForecastRecord {
  id                       String   @id @default(cuid())
  guildId                  String
  marketId                 String
  userId                   String
  resolvedAt               DateTime
  marketTagSnapshot        String[] @default([])
  forecastVector           Json
  resolutionVector         Json?
  winningOutcomeId         String
  winningOutcomeProbability Float
  predictedOutcomeId       String
  brierScore               Float
  wasCorrect               Boolean
  realizedProfit           Float
  tradeCount               Int
  stakeWeight              Float
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  market                   Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([guildId, marketId, userId])
  @@index([marketId])
  @@index([guildId, userId, resolvedAt])
  @@index([guildId, resolvedAt])
  @@index([guildId, brierScore])
}

model MarketOutcome {
  id                   String           @id @default(cuid())
  marketId             String
  label                String
  sortOrder            Int
  outstandingShares    Float            @default(0)
  pricingShares        Float            @default(0)
  settlementValue      Float?
  resolvedAt           DateTime?
  resolvedByUserId     String?
  resolutionNote       String?
  resolutionEvidenceUrl String?
  createdAt            DateTime         @default(now())
  market               Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  trades               MarketTrade[]
  positions            MarketPosition[]
  lossProtections      MarketLossProtection[]
  wonMarkets           Market[]         @relation("MarketWinningOutcome")

  @@unique([marketId, sortOrder])
  @@index([marketId])
}

model MarketLiquidityEvent {
  id                       String   @id @default(cuid())
  marketId                 String
  previousLiquidityParameter Int
  nextLiquidityParameter   Int
  scaleFactor              Float
  bonusAccrued             Float
  createdAt                DateTime @default(now())
  market                   Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}

model MarketTrade {
  id                   String           @id @default(cuid())
  marketId             String
  outcomeId            String
  userId               String
  side                 MarketTradeSide
  cashDelta            Float
  shareDelta           Float
  feeCharged           Float            @default(0)
  probabilitySnapshot  Float
  cumulativeVolume     Float
  createdAt            DateTime         @default(now())
  market               Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome              MarketOutcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
  @@index([marketId, userId, createdAt])
}

model MarketLossProtection {
  id               String        @id @default(cuid())
  marketId         String
  outcomeId        String
  userId           String
  insuredCostBasis Float         @default(0)
  premiumPaid      Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  market           Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome          MarketOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeId, userId])
  @@index([marketId, userId])
  @@index([marketId, outcomeId])
}

model MarketPosition {
  id               String             @id @default(cuid())
  marketId         String
  outcomeId        String
  userId           String
  side             MarketPositionSide @default(long)
  shares           Float              @default(0)
  costBasis        Float              @default(0)
  proceeds         Float              @default(0)
  collateralLocked Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  market           Market             @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome          MarketOutcome      @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeId, userId, side])
  @@index([marketId, userId])
}

model MarketAccount {
  id              String      @id @default(cuid())
  guildConfigId   String
  guildId         String
  userId          String
  bankroll        Float       @default(1000)
  realizedProfit  Float       @default(0)
  lastTopUpAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  guildConfig     GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildConfigId])
  @@index([guildId, bankroll, realizedProfit])
}

model CasinoRoundRecord {
  id         String            @id @default(cuid())
  guildId    String
  userId     String
  game       CasinoGameKind
  wager      Float
  payout     Float
  net        Float
  result     CasinoRoundResult
  details    Json
  createdAt  DateTime          @default(now())

  @@index([guildId, userId, createdAt])
  @@index([guildId, game, createdAt])
}

model CasinoTable {
  id                   String                @id @default(cuid())
  guildId              String
  channelId            String
  messageId            String?               @unique
  threadId             String?               @unique
  hostUserId           String
  name                 String
  game                 CasinoGameKind
  status               CasinoTableStatus     @default(lobby)
  minSeats             Int                   @default(2)
  maxSeats             Int                   @default(6)
  baseWager            Float?
  smallBlind           Float?
  bigBlind             Float?
  defaultBuyIn         Float?
  currentHandNumber    Int                   @default(0)
  actionTimeoutSeconds Int                   @default(30)
  actionDeadlineAt     DateTime?
  noHumanDeadlineAt    DateTime?
  lobbyExpiresAt       DateTime?
  state                Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  guildConfig          GuildConfig           @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  seats                CasinoTableSeat[]
  hands                CasinoTableHand[]
  actions              CasinoTableAction[]

  @@index([guildId, game, status])
  @@index([guildId, status, actionDeadlineAt])
  @@index([guildId, status, noHumanDeadlineAt])
}

model CasinoTableSeat {
  id            String           @id @default(cuid())
  tableId       String
  userId        String
  seatIndex      Int
  status        CasinoSeatStatus @default(seated)
  stack         Float            @default(0)
  reserved      Float            @default(0)
  currentWager  Float            @default(0)
  sitOut        Boolean          @default(false)
  isBot         Boolean          @default(false)
  botId         String?
  botName       String?
  botProfile    Json?
  joinedAt      DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  table         CasinoTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, userId])
  @@unique([tableId, botId])
  @@unique([tableId, seatIndex])
  @@index([tableId, status, seatIndex])
}

model CasinoTableHand {
  id          String         @id @default(cuid())
  tableId      String
  handNumber   Int
  game         CasinoGameKind
  startedAt    DateTime      @default(now())
  completedAt  DateTime?
  snapshot     Json
  table        CasinoTable   @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, handNumber])
  @@index([tableId, completedAt])
}

model CasinoTableAction {
  id          String                 @id @default(cuid())
  tableId      String
  handNumber   Int?
  userId       String?
  action       CasinoTableActionKind
  amount       Float?
  payload      Json?
  createdAt    DateTime               @default(now())
  table        CasinoTable            @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId, createdAt])
  @@index([tableId, handNumber, createdAt])
}

model CasinoUserStat {
  id            String         @id @default(cuid())
  guildId       String
  userId        String
  game          CasinoGameKind
  gamesPlayed   Int            @default(0)
  wins          Int            @default(0)
  losses        Int            @default(0)
  pushes        Int            @default(0)
  tiebreakWins  Int            @default(0)
  currentStreak Int            @default(0)
  bestStreak    Int            @default(0)
  totalWagered  Float          @default(0)
  totalNet      Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([guildId, userId, game])
  @@index([guildId, userId])
  @@index([guildId, game, totalNet])
}

model GuildEventLogEntry {
  id                String                 @id @default(cuid())
  guildId           String
  bucket            AuditLogBucket
  source            AuditLogSource
  eventName         String
  payload           Json
  occurredAt        DateTime               @default(now())
  deliveryStatus    AuditLogDeliveryStatus @default(pending)
  deliveredAt       DateTime?
  deliveredMessageId String?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([guildId, occurredAt])
  @@index([deliveryStatus, occurredAt])
  @@index([deliveryStatus, occurredAt, id])
}

model GuildMessageSnapshot {
  messageId         String   @id
  guildId           String
  channelId         String
  authorId          String?
  firstSeenPayload  Json
  latestPayload     Json
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([guildId, channelId])
  @@index([guildId, updatedAt])
}
