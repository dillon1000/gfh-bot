{
  "name": "gfh-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx watch src/app/index.ts",
    "lint": "biome lint --diagnostic-level=error .",
    "lint:fix": "biome lint --write .",
    "start": "node dist/src/app/index.js",
    "register-commands": "tsx src/app/register-commands.ts",
    "register-commands:dist": "node dist/src/app/register-commands.js",
    "backfill:market-liquidity": "tsx src/app/backfill-market-liquidity.ts",
    "backfill:market-forum-posts": "tsx src/app/backfill-market-forum-posts.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.57",
    "@ai-sdk/xai": "^3.0.77",
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.893.0",
    "@napi-rs/canvas": "^0.1.97",
    "@prisma/client": "^6.7.0",
    "ai": "^6.0.145",
    "bullmq": "^5.56.1",
    "d3": "^7.9.0",
    "discord.js": "^14.20.0",
    "dotenv": "^16.5.0",
    "ioredis": "^5.8.1",
    "mathjax-full": "^3.2.2",
    "pino": "^10.1.0",
    "prisma": "^6.7.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
